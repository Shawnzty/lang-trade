{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Stage Status",
  "type": "object",
  "required": [
    "stage_id",
    "description",
    "state",
    "attempt",
    "dependencies",
    "dependency_tokens",
    "artifacts",
    "preferred_artifacts",
    "inventory",
    "notes",
    "updated_at"
  ],
  "properties": {
    "stage_id": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "state": {
      "type": "string",
      "enum": [
        "not_started",
        "running",
        "completed",
        "failed",
        "stale"
      ]
    },
    "attempt": {
      "type": "integer"
    },
    "started_at": {
      "type": [
        "string",
        "null"
      ]
    },
    "finished_at": {
      "type": [
        "string",
        "null"
      ]
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "dependency_tokens": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "artifacts": {
      "type": "object"
    },
    "preferred_artifacts": {
      "type": "object"
    },
    "inventory": {
      "type": "object",
      "required": [
        "inputs",
        "outputs",
        "edits",
        "logs"
      ],
      "properties": {
        "inputs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "outputs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "edits": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "logs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "last_error": {
      "type": [
        "object",
        "null"
      ]
    },
    "stale_reason": {
      "type": [
        "string",
        "null"
      ]
    },
    "updated_at": {
      "type": "string"
    }
  }
}
